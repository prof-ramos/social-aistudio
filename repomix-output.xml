    const propSizeMap: Record<'xl' | 'lg' | 'md', string> = {
      xl: 'text-4xl',
      lg: 'text-3xl',
      md: 'text-2xl',
    };

    const resolvedSize = size ? propSizeMap[size] : tagSizeMap[Tag];

    return (
      <Tag
        ref={ref}
        className={cn('font-serif font-bold text-navy', resolvedSize, className)}
        {...props}
      >
        {children}
      </Tag>
    );
  }
);

PageTitle.displayName = 'PageTitle';
