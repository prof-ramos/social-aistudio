{
  "entities": {
    "User": {
      "title": "User",
      "description": "Registered standard or admin user",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["MEMBRO_ATIVO", "MEMBRO_APOSENTADO", "ADMIN"] },
        "avatarUrl": { "type": "string" },
        "bio": { "type": "string" },
        "currentPost": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "email", "role", "createdAt"]
    },
    "MemberRequest": {
      "title": "Member Request",
      "description": "A request to join the platform",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "cpf": { "type": "string" },
        "matricula": { "type": "string" },
        "category": { "type": "string", "enum": ["MEMBRO_ATIVO", "MEMBRO_APOSENTADO"] },
        "currentPost": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
        "rejectionReason": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "email", "cpf", "matricula", "category", "status", "createdAt"]
    },
    "Posto": {
      "title": "Posto",
      "description": "A diplomatic post",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "country": { "type": "string" },
        "region": { "type": "string" },
        "slug": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "country", "region", "slug", "createdAt"]
    },
    "PostoField": {
      "title": "Posto Field",
      "description": "An informational field on a posto",
      "type": "object",
      "properties": {
        "postoId": { "type": "string" },
        "fieldType": { "type": "string", "enum": ["SEGURANCA", "CUSTO_VIDA", "SAUDE", "EDUCACAO", "MORADIA", "TRANSPORTE", "GERAL"] },
        "body": { "type": "string" },
        "authorId": { "type": "string" },
        "experienceStart": { "type": "number" },
        "experienceEnd": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["postoId", "fieldType", "body", "authorId", "experienceStart", "experienceEnd", "createdAt"]
    },
    "Post": {
      "title": "Post",
      "description": "A community post",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "body": { "type": "string" },
        "category": { "type": "string", "enum": ["POSTOS", "CARREIRA", "VIDA_EXTERIOR", "APOSENTADORIA", "GERAL"] },
        "pinned": { "type": "boolean" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "body", "category", "pinned", "authorId", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notifications",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "message": { "type": "string" },
        "link": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "type", "message", "read", "createdAt"]
    }
  },
  "firestore": {
    "users": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "memberRequests": {
      "schema": { "$ref": "#/entities/MemberRequest" },
      "description": "Pending and resolved member access requests"
    },
    "postos": {
      "schema": { "$ref": "#/entities/Posto" },
      "description": "Diplomatic posts"
    },
    "postoFields": {
      "schema": { "$ref": "#/entities/PostoField" },
      "description": "Fields of information for a posto"
    },
    "posts": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Community posts in the feed"
    },
    "notifications": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "User notifications"
    }
  }
}
