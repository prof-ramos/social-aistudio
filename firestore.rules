rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedEmail() {
      // NOTE: We don't enforce email verification for requests right away in this demo unless configured
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    function isMember() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['MEMBRO_ATIVO', 'MEMBRO_APOSENTADO', 'ADMIN'];
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // users Validations
    function isValidUsuario(data) {
      return data.keys().hasAll(['name', 'email', 'role', 'createdAt'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() <= 100
        && data.role in ['MEMBRO_ATIVO', 'MEMBRO_APOSENTADO', 'ADMIN']
        && data.createdAt is timestamp
        && (!('bio' in data) || data.bio is string)
        && (!('avatarUrl' in data) || data.avatarUrl is string)
        && (!('currentPost' in data) || data.currentPost is string)
        && (!('savedPosts' in data) || data.savedPosts is list)
        && (!('isOnline' in data) || data.isOnline is bool)
        && (!('lastOnline' in data) || data.lastOnline is timestamp);
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId || isMember();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUsuario(incoming()) && incoming().createdAt == request.time && incoming().email == request.auth.token.email && incoming().role in ["MEMBRO_ATIVO", "MEMBRO_APOSENTADO", "ADMIN"];
      allow update: if isSignedIn() && request.auth.uid == userId && isValidUsuario(incoming()) && incoming().createdAt == existing().createdAt && incoming().email == existing().email && incoming().role == existing().role;
      // Admins can change roles
      allow update: if isAdmin() && isValidUsuario(incoming()) && incoming().createdAt == existing().createdAt;
    }

    // memberRequests Validations
    function isValidMemberRequest(data) {
      return data.keys().hasAll(['name', 'email', 'cpf', 'matricula', 'category', 'status', 'createdAt'])
        && data.name is string && data.name.size() > 0
        && data.email is string && data.email.size() > 0
        && data.cpf is string && data.cpf.size() <= 20
        && data.matricula is string && data.matricula.size() <= 20
        && data.category in ['MEMBRO_ATIVO', 'MEMBRO_APOSENTADO']
        && data.status in ['PENDING', 'APPROVED', 'REJECTED']
        && data.createdAt is timestamp;
    }

    match /memberRequests/{docId} {
      // Anyone can create a request
      allow create: if isValidMemberRequest(incoming()) && incoming().createdAt == request.time && incoming().status == 'PENDING';
      allow read, update, delete: if isAdmin();
    }

    // postos Validations
    function isValidPosto(data) {
      return data.keys().hasAll(['name', 'country', 'region', 'slug', 'createdAt'])
        && data.name is string && data.name.size() > 0
        && data.country is string && data.country.size() > 0
        && data.region is string
        && data.slug is string
        && data.createdAt is timestamp;
    }

    match /postos/{docId} {
      // Members can read
      allow read: if isMember();
      // Admins can create POSTS
      allow create: if isAdmin() && isValidPosto(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidPosto(incoming()) && incoming().createdAt == existing().createdAt;
    }

    // postoFields Validations
    function isValidPostoField(data) {
       return data.keys().hasAll(['postoId', 'fieldType', 'body', 'authorId', 'experienceStart', 'experienceEnd', 'createdAt'])
          && data.postoId is string
          && data.fieldType in ["SEGURANCA", "CUSTO_VIDA", "SAUDE", "EDUCACAO", "MORADIA", "TRANSPORTE", "GERAL"]
          && data.body is string && data.body.size() <= 5000
          && data.authorId == request.auth.uid
          && data.experienceStart is number
          && data.experienceEnd is number
          && data.createdAt is timestamp;
    }

    match /postoFields/{docId} {
      allow read: if isMember();
      allow create: if isMember() && isValidPostoField(incoming()) && incoming().createdAt == request.time;
      allow update: if isMember() && incoming().authorId == request.auth.uid && isValidPostoField(incoming()) && incoming().postoId == existing().postoId && incoming().authorId == existing().authorId && incoming().createdAt == existing().createdAt;
      allow delete: if isMember() && existing().authorId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // posts Validations
    function isValidPost(data) {
      return data.keys().hasAll(['title', 'body', 'category', 'pinned', 'authorId', 'createdAt'])
        && data.title is string && data.title.size() > 0
        && data.body is string && data.body.size() > 0
        && data.category in ["POSTOS", "CARREIRA", "VIDA_EXTERIOR", "APOSENTADORIA", "GERAL"]
        && data.pinned is bool
        && data.createdAt is timestamp
        && (!('reactions' in data) || data.reactions is map)
        && (!('authorName' in data) || data.authorName is string)
        && (!('authorRole' in data) || data.authorRole is string);
    }

    match /posts/{docId} {
      allow read: if isMember();
      allow create: if isMember() && isValidPost(incoming()) && incoming().authorId == request.auth.uid && incoming().createdAt == request.time;
      allow update: if isMember() && (
        (incoming().authorId == request.auth.uid && isValidPost(incoming()) && incoming().authorId == existing().authorId && incoming().createdAt == existing().createdAt)
        ||
        (
          !('title' in incoming().diff(existing()).affectedKeys()) &&
          !('body' in incoming().diff(existing()).affectedKeys()) &&
          !('authorId' in incoming().diff(existing()).affectedKeys()) &&
          !('createdAt' in incoming().diff(existing()).affectedKeys()) &&
          (!('reactions' in incoming()) || incoming().reactions is map)
        )
      );
      allow delete: if isMember() && existing().authorId == request.auth.uid;
      allow delete: if isAdmin();
      
      // Comments Subcollection
      match /comments/{commentId} {
        allow read: if isMember();
        allow create: if isMember() && incoming().createdAt == request.time && incoming().authorId == request.auth.uid;
        allow update: if isMember() && existing().authorId == request.auth.uid && incoming().authorId == existing().authorId && incoming().createdAt == existing().createdAt;
        allow delete: if isMember() && existing().authorId == request.auth.uid;
        allow delete: if isAdmin();
      }
    }

    // reports Validations
    match /reports/{docId} {
      allow read, update, delete: if isAdmin();
      allow create: if isMember() && incoming().createdAt == request.time;
    }

    // notifications Validations
    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'type', 'message', 'read', 'createdAt'])
        && data.userId is string
        && data.type is string
        && data.message is string
        && data.read is bool
        && data.createdAt is timestamp;
    }

    match /notifications/{docId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if isMember() || isAdmin();
      allow update: if isSignedIn() && request.auth.uid == existing().userId && incoming().userId == existing().userId && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == existing().userId);
    }

    // chats Validations
    match /chats/{chatId} {
      allow read, update: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }
  }
}
